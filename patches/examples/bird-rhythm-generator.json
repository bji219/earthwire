    {
      "sourceId": "ebird-activity",
      "fieldId": "species-diversity",
      "normalizer": { "mode": "auto" },
      "smoother": { "amount": 0.4 },
      "quantizer": { "root": 60, "scale": "pentatonic" },
      "threshold": null,
      "output": { "type": "midi-note", "channel": 2 }
    }
  ]
}
