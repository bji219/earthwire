# eBird API key (get one free at https://ebird.org/api/keygen)
EBIRD_API_KEY=your_key_here

# Freesound API (required for Freesound tab in Sample Browser)
# Register at: https://freesound.org/apiv2/apply/
FREESOUND_CLIENT_ID=your_client_id_here

# Xeno-canto API key (optional — keyless works currently)
# XENO_CANTO_KEY=
